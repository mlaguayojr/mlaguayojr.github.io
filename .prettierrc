{
  "semi": true,
  "singleQuote": false,
  "trailingComma": "es5",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "htmlWhitespaceSensitivity": "css",
  "overrides": [
    {
      "files": ["_includes/**/*", "_layouts/**/*", "_posts/**/*", "*.html"],
      "options": {
        "parser": "babel"
      }
    },
    {
      "files": "*.yml",
      "options": {
        "parser": "yaml"
      }
    }
  ],
  "ignorePatterns": ["_site/", "node_modules/", "_includes/**", "_layouts/**", "_posts/**"]
}
